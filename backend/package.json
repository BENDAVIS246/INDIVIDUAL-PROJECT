{
  "name": "excel-admission-backend",
  "version": "1.0.0",
  "description": "Backend API for Online Application and Admission System",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "migrate": "typeorm migration:run",
    "migration:create": "typeorm migration:create",
    "typeorm": "typeorm"
  },
  "keywords": ["admission", "api", "backend"],
  "authors": ["TUMUSIIME DAVIS", "AGABA CRANMER"],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.1.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "pdfkit": "^0.13.0",
    "pino": "^8.17.2",
    "redis": "^4.6.12",
    "sendgrid": "^5.2.3",
    "stripe": "^14.0.0",
    "twilio": "^4.10.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
